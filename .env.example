# Web3Forms (https://web3forms.com) — optional overrides (defaults are baked in for production).
# Copy to `.env.local` if you rotate keys. `.env.local` is gitignored.

VITE_WEB3FORMS_REGISTRATION_ACCESS_KEY=
VITE_WEB3FORMS_VOLUNTEER_ACCESS_KEY=

# Vercel / serverless Stripe Checkout (set in Vercel → Settings → Environment Variables, not in git):
# STRIPE_SECRET_KEY=sk_live_... or sk_test_...
# SITE_URL=https://your-custom-domain.com   (optional; also add to ALLOWED_ORIGINS if you use www vs apex)
# ALLOWED_ORIGINS=https://a.com,https://b.com   (optional extra tab origins for checkout return URLs)

# Local Stripe API (server/.env): if you do not use localhost, set FRONTEND_ORIGIN and ALLOWED_ORIGINS
# to the exact origin you open in the browser (see server/.env.example).

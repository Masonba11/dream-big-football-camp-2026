# Copy to .env (gitignored) and fill in.

STRIPE_SECRET_KEY=

# Default tab URL for the Vite app (used if checkout omits clientOrigin fallback).
# If you open the site at http://192.168.x.x:3000 or http://my-machine.local:3000, set that here
# and list it again under ALLOWED_ORIGINS (comma-separated) so Stripe return URLs match.
FRONTEND_ORIGIN=http://localhost:3000

# Extra allowed tab origins (comma-separated). Required when you use LAN IP / hostname / tunnel URL.
# Example: ALLOWED_ORIGINS=http://192.168.1.10:3000,http://my-mac.local:3000
ALLOWED_ORIGINS=
